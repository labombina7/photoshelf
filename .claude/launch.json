{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "photoshelf",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "photoshelf-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000
    },
    {
      "name": "docs",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs", "-p", "8080", "--no-clipboard"],
      "port": 8080
    }
  ]
}
