# Contraseña de acceso a la app (la que escribes en el login)
APP_PASSWORD=change_me_strong_password

# Secreto de sesión — mínimo 32 caracteres aleatorios
# Genera uno con: openssl rand -hex 32
SESSION_SECRET=change_me_32_char_random_secret_here

# IP local de tu Mac donde corre Ollama
# Encuéntrala con: ifconfig | grep "inet 192"
OLLAMA_URL=http://192.168.1.XXX:11434

# Rutas dentro del contenedor (no cambiar salvo que montes diferente)
# PHOTOS_PATH=/photos
# CACHE_PATH=/data/.cache
# DB_PATH=/data/photoshelf.db
