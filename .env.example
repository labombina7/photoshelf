# Contraseña de acceso a la app (la que escribes en el login)
APP_PASSWORD=change_me_strong_password

# Secreto de sesión — mínimo 32 caracteres aleatorios
# Genera uno con: openssl rand -hex 32
SESSION_SECRET=change_me_32_char_random_secret_here

# URL donde corre Ollama (para clasificación automática de fotos con IA)
# Usa host.docker.internal para acceder al Ollama del host desde el contenedor
OLLAMA_URL=http://host.docker.internal:11434

# Concurrencia de Ollama — número de requests paralelos que acepta el servidor.
# Configúralo en el entorno donde arranca Ollama (no en Docker de photoshelf):
#   OLLAMA_NUM_PARALLEL=2 ollama serve
# Valor recomendado para M1 16GB con llava:7b: 2. No subir a 3+ (riesgo de swap).

# Ruta en el HOST donde están tus fotos (se monta como solo lectura en el contenedor)
PHOTOS_MOUNT=/ruta/a/tus/fotos

# Ruta DENTRO del contenedor donde se exponen las fotos (debe coincidir con PHOTOS_PATH)
# PHOTOS_PATH=/photos

# Ruta del host donde se almacena photoshelf.db y la caché de miniaturas.
# Debe apuntar a una carpeta con escritura para el proceso del contenedor (UID 1000).
DATA_PATH=/ruta/a/photoshelf-data

# Rutas internas del contenedor (no cambiar salvo que montes diferente)
# CACHE_PATH=/data/.cache
# DB_PATH=/data/photoshelf.db
# BACKUP_PATH=/data/backups
